{
  "name": "mbox-crawler",
  "version": "1.0.0",
  "private": false,
  "description": "A Node.js application to process Gmail MBOX files and extract, validate, and deduplicate email addresses with stream-based processing for efficient handling of large email archives.",
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/mbox-crawler.git"
  },
  "keywords": [
    "mbox",
    "email",
    "email-extraction",
    "email-parser",
    "email-validation",
    "gmail",
    "gmail-export",
    "email-addresses",
    "deduplication",
    "contact-management",
    "email-crawler",
    "stream-processing",
    "node",
    "nodejs",
    "email-archive",
    "contacts",
    "email-mining"
  ],
  "license": "MIT",
  "author": "Or Assayag <orassayag@gmail.com>",
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "files": [
    "src",
    ".eslintignore",
    ".eslintrc",
    ".gitignore",
    ".jsbeautifyrc",
    ".npmignore",
    "CONTRIBUTING.md",
    "INSTRUCTIONS.md",
    "LICENSE",
    "package-lock.json",
    "package.json",
    "README.md"
  ],
  "main": "src/scripts/crawl.script.js",
  "scripts": {
    "backup": "node src/scripts/backup.script.js",
    "start": "node src/scripts/crawl.script.js",
    "stop": "taskkill -f -im node.exe"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "check-disk-space": "^3.4.0",
    "fs-extra": "^11.3.4",
    "line-by-line": "^0.1.6",
    "node-mbox": "^2.0.0",
    "table": "^6.9.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "eslint": "^10.0.2"
  }
}